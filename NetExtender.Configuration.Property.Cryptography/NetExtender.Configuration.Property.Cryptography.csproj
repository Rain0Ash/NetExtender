<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net6.0;net7.0;net8.0;net9.0;net10.0</TargetFrameworks>
        <Nullable>enable</Nullable>
        <ImplicitUsings>disable</ImplicitUsings>
        <OutputType>Library</OutputType>
        <Authors>Rain0Ash</Authors>
        <PackageProjectUrl>https://github.com/Rain0Ash/NetExtender</PackageProjectUrl>
        <Version>0.8.9</Version>
        <SignAssembly>true</SignAssembly>
        <AssemblyOriginatorKeyFile>../SignTool/Private/NetExtender.snk</AssemblyOriginatorKeyFile>
        <Title>NetExtender.Configuration.Property.Cryptography</Title>
        <Description>Configuration Cryptography Property module of NetExtender Framework</Description>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/Rain0Ash/NetExtender</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>Extension</PackageTags>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <IsPackable>true</IsPackable>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\NetExtender.Configuration.Cryptography\NetExtender.Configuration.Cryptography.csproj"/>
        <ProjectReference Include="..\NetExtender.Configuration.Property\NetExtender.Configuration.Property.csproj"/>
        <ProjectReference Include="..\NetExtender.Cryptography\NetExtender.Cryptography.csproj"/>
        <ProjectReference Include="..\NetExtender.Configuration\NetExtender.Configuration.csproj"/>
        <ProjectReference Include="..\NetExtender.Core\NetExtender.Core.csproj"/>
    </ItemGroup>

</Project>
