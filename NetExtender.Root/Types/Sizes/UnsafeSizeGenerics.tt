    void UnsafeSize()
    {
        static IEnumerable<Int32> GenerateNumbers(Int32 limit)
        {
            Int32 current = 8;

            while (current <= limit)
            {
                yield return current;
                Int32 step = current switch
                {
                    < 64 => 8,
                    < 256 => 32,
                    < 512 => 64,
                    < 1024 => 128,
                    _ => 256
                };

                current += step;
            }
        }

        ForEach(GenerateNumbers(4096).Select(static number => number.ToString()), UnsafeSizeImplementation);
    }
