    void NextSignFunc(String type)
    {
        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine(
                $"\t\tpublic static {type} {nameof(NextSign)}{type}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{nameof(Double)} chance = 0.5)");
            WriteLine("\t\t{");

            WriteLine(item is null
                ? $"\t\t\treturn {nameof(NextSign)}{type}({Generator}, chance);"
                : $"\t\t\treturn {(IsUnsignedType(type) ? "1" : $"{nameof(Next)}{nameof(Boolean)}({item.Value.Item2}, chance) ? 1 : -1")};");

            WriteLine("\t\t}");

            if (item != random.Last())
            {
                WriteLine(String.Empty);
            }
        }
    }

    void NextSign()
    {
        ForEach(types.Where(type => !IsUnsignedType(type)), NextSignFunc, false);
    }

    void RangeFunc(String type)
    {
        if (type == nameof(Int32))
        {
            foreach ((String, String)? item in random)
            {
                WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
                WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(Range)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 : String.Empty)})");
                WriteLine("\t\t{");
                WriteLine($"\t\t\treturn {type}{nameof(Range)}({(item.HasValue ? item.Value.Item2 + $", {type}.MinValue, {type}.MaxValue" : Generator)});");
                WriteLine("\t\t}");

                WriteLine(String.Empty);
            }
        }

        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(Range)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} max)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {type}{nameof(Range)}({(item.HasValue ? item.Value.Item2 : Generator)}{(item.HasValue ? $", {type}.MinValue" : String.Empty)}, max);");
            WriteLine("\t\t}");

            WriteLine(String.Empty);
        }

        if (type != nameof(Int32))
        {
            foreach ((String, String)? item in random)
            {
                WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
                WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(Range)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} max, Int32 count)");
                WriteLine("\t\t{");
                WriteLine($"\t\t\treturn {type}{nameof(Range)}({(item.HasValue ? item.Value.Item2 : Generator)}{(item.HasValue ? $", {type}.MinValue" : String.Empty)}, max, count);");
                WriteLine("\t\t}");

                WriteLine(String.Empty);
            }
        }

        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(Range)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} min, {type} max)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {nameof(Range)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}min, max, {nameof(Next)}{type});");
            WriteLine("\t\t}");

            WriteLine(String.Empty);
        }

        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(Range)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} min, {type} max, Int32 count)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {nameof(Range)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}min, max, count, {nameof(Next)}{type});");
            WriteLine("\t\t}");

            if (item != random.Last())
            {
                WriteLine(String.Empty);
            }
        }
    }

