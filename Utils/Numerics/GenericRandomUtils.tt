    void NonZeroRangeFunc(String type)
    {
        if (type == nameof(Int32))
        {
            foreach ((String, String)? item in random)
            {
                WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
                WriteLine($"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(NonZeroRange)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 : String.Empty)})");
                WriteLine("\t\t{");
                WriteLine($"\t\t\treturn {type}{nameof(NonZeroRange)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}{type}.MinValue, {type}.MaxValue);");
                WriteLine("\t\t}");
                
                WriteLine(String.Empty);
            }
        }
        
        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine(
                $"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(NonZeroRange)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} max)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {type}{nameof(NonZeroRange)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}{type}.MinValue, max);");
            WriteLine("\t\t}");

            WriteLine(String.Empty);
        }

        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine(
                $"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(NonZeroRange)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} min, {type} max)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {nameof(Range)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}min, max, {nameof(NextNonZero)}{type});");
            WriteLine("\t\t}");
            
            WriteLine(String.Empty);
        }
        
        foreach ((String, String)? item in random)
        {
            WriteLine("\t\t[MethodImpl(MethodImplOptions.AggressiveInlining)]");
            WriteLine(
                $"\t\tpublic static {nameof(IEnumerable)}<{type}> {type}{nameof(NonZeroRange)}({(item.HasValue ? "this " + item.Value.Item1 + " " + item.Value.Item2 + ", " : String.Empty)}{type} min, {type} max, Int32 count)");
            WriteLine("\t\t{");
            WriteLine($"\t\t\treturn {nameof(Range)}({(item.HasValue ? item.Value.Item2 + ", " : String.Empty)}min, max, count, {nameof(NextNonZero)}{type});");
            WriteLine("\t\t}");
            
            if (item != random.Last())
            {
                WriteLine(String.Empty);
            }
        }
    }

    void NonZeroRange()
    {
        ForEach(types, NonZeroRangeFunc, false);
    }
